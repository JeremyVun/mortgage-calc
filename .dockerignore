# The image is built in two stages: a Node stage runs `vite build`, then nginx
# serves the result. The build context therefore needs the SOURCE Vite consumes
# (index.html, src/, package*.json, vite.config.js) — everything below is dev/ops
# cruft or artifacts rebuilt inside the image.
.git
.gitignore
.claude
.dockerignore
Dockerfile
docker-bake.hcl
versions.hcl
*.md

# installed/built locally — regenerated inside the build stage
node_modules
dist

# local env
.env
*.local

# OS / editor
.DS_Store
